# =============================================================================
#  THIS POC NEEDS NO SECRETS.
# =============================================================================
# There are deliberately NO API keys and NO database URLs here. The backend is
# the llm-d inference *simulator*, which loads no model weights and calls no
# external service. Everything runs on a local `kind` cluster for $0.
#
# This file documents the OPTIONAL knobs you can override. Copy to `.env` only
# if you want to change a default; the scripts work with zero configuration.
#
#   cp .env.example .env   # optional
# =============================================================================

# --- Cluster / namespace ---
# CLUSTER_NAME=llm-serve
# NAMESPACE=llm-serving

# --- Pinned upstream versions (bump deliberately) ---
# IGW_RELEASE=v1.5.0            # gateway-api-inference-extension
# GATEWAY_API_RELEASE=v1.5.1    # sigs.k8s.io/gateway-api CRDs
# ISTIO_VERSION=1.28.0         # >=1.28 required
# SIM_IMAGE=ghcr.io/llm-d/llm-d-inference-sim:v0.8.2

# --- Routing identity (model name is cosmetic; the sim loads no weights) ---
# MODEL_NAME=meta-llama/Llama-3.1-8B-Instruct
# POOL_NAME=llama3-8b-pool
# POOL_LABEL_APP=llama3-8b
# GATEWAY_NAME=inference-gateway
# GATEWAY_PROVIDER=istio
